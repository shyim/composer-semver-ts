{
  "name": "composer-semver",
  "version": "0.1.0",
  "description": "Composer-style semantic version parsing and constraint matching for JavaScript",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "tsdown": "^0.16.6",
    "typescript": "^5.9.2"
  }
}
